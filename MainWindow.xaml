<Window x:Class="AudioMonitorRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio Recorder" Height="420" Width="450"
        Background="#1e1e1e">

    <StackPanel Margin="15">

        <TextBlock x:Name="RecText" Text="● STOP" Foreground="Gray" FontSize="18"/>
        <TextBlock x:Name="TimeText" Text="00:00:00" Foreground="White" FontSize="16"/>

        <TextBlock Text="マイク選択" Foreground="White"/>
        <ComboBox x:Name="InputDeviceBox" Margin="0,5"/>

        <TextBlock Text="保存設定" Foreground="White" Margin="0,15,0,5"/>

        <TextBlock Text="ファイル名" Foreground="LightGray"/>
        <TextBox x:Name="FileNameBox" Text="record"/>

        <TextBlock Text="形式" Foreground="LightGray"/>
        <ComboBox x:Name="FormatBox">
            <ComboBoxItem Content="WAV"/>
            <ComboBoxItem Content="MP3"/>
        </ComboBox>

        <TextBlock Text="保存先フォルダ" Foreground="LightGray"/>
        <DockPanel>
            <TextBox x:Name="FolderPathBox" IsReadOnly="True" Width="300"/>
            <Button Content="選択" Click="SelectFolder_Click" Margin="5,0"/>
        </DockPanel>

        <CheckBox x:Name="MonitorCheck" Content="録音中の音をスピーカーに出す"
                  Foreground="White" IsChecked="True" Margin="0,10"/>

        <StackPanel Orientation="Horizontal">
            <Button x:Name="StartBtn" Content="録音開始" Click="Start_Click" Width="120" Margin="5"/>
            <Button x:Name="StopBtn" Content="停止して保存" Click="Stop_Click" Width="120" Margin="5" IsEnabled="False"/>
        </StackPanel>

    </StackPanel>
</Window>